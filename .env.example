# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# Required: Anthropic API key for Claude LLM responses
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides (defaults shown)
TRIAGE_LLM_PROVIDER=anthropic          # anthropic | rules
TRIAGE_LLM_MODEL=claude-sonnet-4-6
TRIAGE_DATA_DIR=data
TRIAGE_INPUT_CSV=support_tickets/support_tickets.csv
TRIAGE_OUTPUT_CSV=support_tickets/output.csv
TRIAGE_LOG_LEVEL=info                  # info | debug | warn | error
